# 阿里云 DashScope（OpenAI 兼容模式）
SEMENTIC_LLM_PROVIDER=aliyun
SEMENTIC_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
SEMENTIC_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
SEMENTIC_LLM_MODEL=qwen-plus-2025-07-28
SEMENTIC_LLM_TIMEOUT_SECONDS=180

# Stage-1 task intent gate (future local small model)
# SEMENTIC_INTENT_LLM_PROVIDER=aliyun
# SEMENTIC_INTENT_LLM_MODEL=qwen-turbo
# SEMENTIC_INTENT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# Redis 聊天窗口
SEMENTIC_REDIS_URL=redis://localhost:6379/0
SEMENTIC_REDIS_MAX_MESSAGES=20
SEMENTIC_REDIS_PLANNER_WINDOW=10

# Kafka
# Kafka（Windows 访问 WSL 内 Kafka 时使用 WSL IP）
SEMENTIC_KAFKA_BOOTSTRAP_SERVERS=192.168.233.121:9092
SEMENTIC_KAFKA_TOPIC=im.messages
SEMENTIC_KAFKA_GROUP_ID=sementic-worker

# Worker main loop tick (seconds); Kafka runs in a background thread
SEMENTIC_WORKER_MAIN_LOOP_INTERVAL_SECONDS=1.0

# Multica IM agents API (internal token via MULTICA_IM_INTERNAL_TOKEN / file)
# GET {SEMENTIC_BOT_AGENTS_URL}?team_id=<mm_team>&owner_user_id=<mm_user_id>
SEMENTIC_BOT_AGENTS_URL=http://127.0.0.1:8080/api/im/mattermost/agents
# MULTICA_IM_INTERNAL_TOKEN=
# HERMES_INTERNAL_BRIDGE_TOKEN=
# fallback file: /etc/mattermost-hermes-im-internal-token

# Multica control-plane base URL (per-user multica_token comes from IM user props)
SEMENTIC_MULTICA_SERVICE_BASE=http://127.0.0.1:8080/api/multica

# In-process MAOS / Temporal execution (maos_runtime merged into worker)
SEMENTIC_MAOS_TEMPORAL_ADDRESS=127.0.0.1:7233
SEMENTIC_MAOS_TEMPORAL_NAMESPACE=default
SEMENTIC_MAOS_MULTICA_JOB_API_BASE=http://127.0.0.1:8080
# Optional process-wide fallbacks; per-message credentials come from graph.input
# SEMENTIC_MAOS_MULTICA_JOB_TOKEN=
# SEMENTIC_MAOS_MULTICA_JOB_WORKSPACE_ID=

# MAOS task observer (read-only UI + export; colocated with worker, binds 0.0.0.0)
# SEMENTIC_MAOS_OBSERVER_ENABLED=true
# SEMENTIC_MAOS_OBSERVER_PORT=8766

# Worker-side Mattermost egress (external_ingress; Redis key shared:service_token, env INTERNAL_SERVICE_TOKEN)
# SEMENTIC_MM_URL=http://127.0.0.1:8065
# SEMENTIC_MM_ENABLED=true
# SEMENTIC_MM_POLL_INTERVAL_SECONDS=5
# SEMENTIC_MM_COMPLETION_TIMEOUT_SECONDS=7200
# Legacy fallback (per-bot MM access tokens):
# SEMENTIC_MM_DEFAULT_BOT_TOKEN=
# SEMENTIC_MM_BOT_TOKENS_JSON={"mdjubgcor3f1mxdzgptdm8pghw":"mm_bot_token_for_codex"}

# Gateway
SEMENTIC_GATEWAY_HOST=0.0.0.0
SEMENTIC_GATEWAY_PORT=8080
