# 阿里云 DashScope（OpenAI 兼容模式）
SEMENTIC_LLM_PROVIDER=aliyun
SEMENTIC_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
SEMENTIC_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
SEMENTIC_LLM_MODEL=qwen-plus-2025-07-28
SEMENTIC_LLM_TIMEOUT_SECONDS=180

# Stage-1 task intent gate (future local small model)
# SEMENTIC_INTENT_LLM_PROVIDER=aliyun
# SEMENTIC_INTENT_LLM_MODEL=qwen-turbo
# SEMENTIC_INTENT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# Redis 聊天窗口
SEMENTIC_REDIS_URL=redis://localhost:6379/0
SEMENTIC_REDIS_MAX_MESSAGES=20
SEMENTIC_REDIS_PLANNER_WINDOW=10

# Kafka
# Kafka（Windows 访问 WSL 内 Kafka 时使用 WSL IP）
SEMENTIC_KAFKA_BOOTSTRAP_SERVERS=192.168.233.121:9092
SEMENTIC_KAFKA_TOPIC=im.messages
SEMENTIC_KAFKA_GROUP_ID=sementic-worker

# Worker main loop tick (seconds); Kafka runs in a background thread
SEMENTIC_WORKER_MAIN_LOOP_INTERVAL_SECONDS=1.0

# Bot management service base address (path is fixed: GET /api/v1/bots?user_id=...)
# Windows 访问 WSL OpenResty 示例: http://192.168.233.121
SEMENTIC_BOT_SERVICE_BASE=http://127.0.0.1

# Gateway
SEMENTIC_GATEWAY_HOST=0.0.0.0
SEMENTIC_GATEWAY_PORT=8080
