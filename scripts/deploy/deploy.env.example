# Copy to scripts/deploy/deploy.env (gitignored) and fill in values.

# SSH
DEPLOY_HOST=1.95.200.170
DEPLOY_USER=root
DEPLOY_SSH_PASSWORD=

# Optional: use key instead of password
# DEPLOY_SSH_KEY_PATH=C:\Users\you\.ssh\id_rsa

# LLM API key (falls back to SEMENTIC_LLM_API_KEY in repo-root .env if empty)
SEMENTIC_LLM_API_KEY=

# Temporal PostgreSQL (optional; auto-generated on remote if empty)
# TEMPORAL_POSTGRES_PASSWORD=

# Worker MM egress: Redis shared:service_token (optional; preserved/generated on remote if empty)
# MM_EXTERNAL_INGRESS_TOKEN=
