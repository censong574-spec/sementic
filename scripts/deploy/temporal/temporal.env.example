# Temporal Server — see scripts/deploy/remote.toml [temporal] and DEPLOY.md
#
# persistence: sqlite (local dev) | postgres (cloud)
persistence = "postgres"
remote_root = "/opt/temporal"
grpc_host = "127.0.0.1"
grpc_port = 7233
ui_port = 8233
cli_version = "1.3.0"
server_version = "1.27.2"
service_name = "temporal-server"
namespace = "default"

# PostgreSQL on same host (postgresql-14-custom.service)
postgres_host = "127.0.0.1"
postgres_port = 5432
postgres_user = "temporal"
postgres_db = "temporal"
postgres_visibility_db = "temporal_visibility"
postgres_custom_root = "/opt/postgresql-14"
postgres_admin_socket = "/tmp"

# Remote dirs searched for pre-uploaded temporal_*_linux_amd64.tar.gz (colon-separated)
bundle_fallback_dirs = "/home/liusong"

# Password: scripts/deploy/deploy.env -> TEMPORAL_POSTGRES_PASSWORD (auto on remote if empty)

# Fallback when persistence = sqlite
db_file = "/opt/temporal/data/temporal.db"
